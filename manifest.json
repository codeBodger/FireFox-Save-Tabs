{
  "manifest_version": 2,
  "name": "Save Tabs to Text: Keybind",
  "version": "0.3.0",
  "description": "Save tabs to a text file.",
  "browser_specific_settings": {
    "gecko": {
      "id": "{e2e78d6e-becd-43d8-ac46-659d2435c857}",
      "data_collection_permissions": {
      	"required": ["browsingActivity"],
        "optional": []
      }
    }
  },
  "icons": {
    "48": "icons/icon48.png"
  },
  "permissions": [
    "tabs",
    "storage",
    "downloads",
    "clipboardWrite"
  ],
  "browser_action": {
    "default_icon": "icons/icon32.png",
    "default_title": "Save Tabs",
    "default_popup": "save_dialog.html"
  },
  "background": {
    "scripts": [
      "tabtxt.js"
    ],
    "persistent": false
  },
  "commands": {
    "_execute_browser_action": {
      "suggested_key": {
        "default": "Ctrl+S"
      }
    }
  }
}
